# ─────────────────────────────────────────────────────────────────────────────
# Job Seeker's Concierge — Environment Variables
# Copy this file to .env and fill in the real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Firebase service account credentials as a SINGLE-LINE minified JSON string.
#
# How to get it:
#   1. Go to Firebase Console → Project Settings → Service Accounts.
#   2. Click "Generate new private key" — this downloads a .json file.
#   3. Minify that JSON into one line (remove all newlines/extra spaces).
#      Quick command:  python3 -c "import json,sys; print(json.dumps(json.load(open('serviceAccount.json'))))"
#   4. Paste the resulting single-line string as the value below.
#
# Example shape (do NOT paste the raw .json file — it must be one line):
#   FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=
